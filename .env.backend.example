# Copy this file to .env.backend on the Oracle VM and replace every placeholder.
# Full-stack Oracle: use the application hostname, for example events.example.com.
# Backend-only Oracle: use the API hostname, for example api.example.com.
CADDY_ADDRESS=service.example.com

MYSQL_DATABASE=event_manager
MYSQL_USER=event_manager
MYSQL_PASSWORD=replace-with-a-long-random-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-long-random-password
DATABASE_URL=mysql+pymysql://event_manager:replace-with-a-long-random-password@mysql:3306/event_manager

APP_SECRET_KEY=replace-with-at-least-32-random-characters
# Full-stack Oracle: use the Caddy application origin.
# Backend-only Oracle: use the separately deployed Vercel frontend origin.
# Do not include a trailing slash.
PUBLIC_APP_URL=https://frontend.example.com
COOKIE_SECURE=true
ADMIN_SESSION_HOURS=12
VENDOR_SESSION_IDLE_MINUTES=30
PENDING_PAYMENT_MINUTES=5
ADMIN_WALLET_PREVIEW_MINUTES=5

# Production email delivery. PUBLIC_APP_URL must be public HTTPS when templates use
# uploaded images, because email clients fetch those images without authentication.
ENVIRONMENT=production
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Event Manager
SMTP_STARTTLS=true
SMTP_SSL=false
SMTP_TIMEOUT_SECONDS=20
EMAIL_TEST_RECIPIENT=
DEVELOPMENT_EMAIL_DELIVERY_LIMIT=3
