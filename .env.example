MYSQL_DATABASE=event_manager
MYSQL_USER=event_manager
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-me
DATABASE_URL=mysql+pymysql://event_manager:change-me@mysql:3306/event_manager
APP_SECRET_KEY=replace-with-at-least-32-random-characters
PUBLIC_APP_URL=http://localhost:3000
COOKIE_SECURE=false
ADMIN_SESSION_HOURS=12
VENDOR_SESSION_IDLE_MINUTES=30
PENDING_PAYMENT_MINUTES=5
ADMIN_WALLET_PREVIEW_MINUTES=5
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
NEXT_PUBLIC_API_BASE=/api/v1

# Email delivery. Development mode simulates delivery unless EMAIL_TEST_RECIPIENT is set.
ENVIRONMENT=development
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Event Manager
SMTP_STARTTLS=true
SMTP_SSL=false
SMTP_TIMEOUT_SECONDS=20
EMAIL_TEST_RECIPIENT=
DEVELOPMENT_EMAIL_DELIVERY_LIMIT=3
